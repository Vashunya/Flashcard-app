  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login (Get Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"твой_логин_админа\",\n    \"password\": \"твой_пароль_админа\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "login",
                ""
              ]
            },
            "description": "Sends login and password, returns a token. This token must be copied and pasted into the collection variables (Variables tab) for the rest of the queries to work."
          },
          "response": []
        }
      ],
      "description": "This folder contains authentication requests used to log in and obtain an access token for authorized API calls."
    },
